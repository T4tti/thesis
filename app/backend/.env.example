# Copy to ".env" and fill in values.
# Local Postgres (default in `database.py`):
# DATABASE_URL=postgresql://vnrate_user:vnrate_password@localhost:5432/vnrate_db
#
# If running the backend in Docker while Postgres runs on your host machine:
# DATABASE_URL=postgresql://vnrate_user:vnrate_password@host.docker.internal:5432/vnrate_db
#
# If using docker-compose with a "db" service:
# DATABASE_URL=postgresql://vnrate_user:vnrate_password@db:5432/vnrate_db

DATABASE_URL=

