{"metadata":{"kernelspec":{"display_name":"Python 3","language":"python","name":"python3"},"language_info":{"name":"python","version":"3.10.0"},"kaggle":{"accelerator":"none","dataSources":[{"sourceType":"datasetVersion","sourceId":16265572,"datasetId":9756080,"databundleVersionId":17249890},{"sourceType":"datasetVersion","sourceId":16379180,"datasetId":10499646,"databundleVersionId":17372540}],"dockerImageVersionId":31328,"isInternetEnabled":true,"language":"python","sourceType":"notebook","isGpuEnabled":false}},"nbformat_minor":5,"nbformat":4,"cells":[{"id":"cace3af8-78e1-46d7-8dcd-b712de04713f","cell_type":"markdown","source":"# Kịch bản 7: FI-TTX — Fuzzy Choquet Integral Ensemble\n\nKết hợp **3 mô hình** bằng Fuzzy Choquet Integral:\n- **T-BiLSTM** (Transformer + Bidirectional LSTM)\n- **TCN** (Temporal Convolutional Network)\n- **XGBoost** (Gradient Boosted Trees)\n\n> Học Fuzzy Measure μ(A) từ validation, tính Shapley values.","metadata":{}},{"id":"1c150676-0502-4d58-881a-88174f2c20f6","cell_type":"markdown","source":"## 1. Môi trường & Thư viện","metadata":{}},{"id":"2d175f18","cell_type":"code","source":"import os, sys, platform, random, warnings, itertools, math\nwarnings.filterwarnings('ignore')\n\nimport numpy as np\nimport pandas as pd\nimport matplotlib.pyplot as plt\nimport seaborn as sns\nfrom pathlib import Path\nfrom typing import Dict, List, Optional, Tuple\n\nfrom scipy.optimize import minimize\nfrom sklearn.metrics import (\n    accuracy_score, f1_score, cohen_kappa_score,\n    roc_auc_score, confusion_matrix, classification_report,\n    precision_score, recall_score,\n)\nfrom sklearn.preprocessing import LabelEncoder, label_binarize\n\nSEED = 42\nrandom.seed(SEED); np.random.seed(SEED)\n\ndef _detect_kaggle():\n    return bool(os.environ.get('KAGGLE_KERNEL_RUN_TYPE','')) or (\n        Path('/kaggle/input').exists() and Path('/kaggle/working').exists())\n\nIN_KAGGLE = _detect_kaggle()\n\ndef _find_root(start):\n    for p in [start, *start.parents]:\n        if (p/'data').exists() and (p/'src').exists(): return p\n    return start\n\nPROJECT_ROOT = Path('/kaggle/working') if IN_KAGGLE else _find_root(Path.cwd().resolve())\nARTIFACT_DIR = PROJECT_ROOT / 'credit_rating_artifacts'\nARTIFACT_DIR.mkdir(parents=True, exist_ok=True)\n\n# Kaggle input dataset for pre-computed model probabilities (.npy)\nPROBA_INPUT_DIR = Path('/kaggle/input/datasets/tailength/model-proba/proba') if IN_KAGGLE else ARTIFACT_DIR\n\nprint('Python:', platform.python_version())\nprint('Kaggle:', IN_KAGGLE)\nprint('ROOT  :', PROJECT_ROOT)\nprint('ART   :', ARTIFACT_DIR)\n","metadata":{"execution":{"iopub.status.busy":"2026-05-21T05:32:46.106661Z","iopub.execute_input":"2026-05-21T05:32:46.107052Z","iopub.status.idle":"2026-05-21T05:32:46.119441Z","shell.execute_reply.started":"2026-05-21T05:32:46.107022Z","shell.execute_reply":"2026-05-21T05:32:46.118213Z"},"trusted":true},"outputs":[{"name":"stdout","text":"Python: 3.12.12\nKaggle: True\nROOT  : /kaggle/working\nART   : /kaggle/working/credit_rating_artifacts\n","output_type":"stream"}],"execution_count":36},{"id":"50140f86","cell_type":"markdown","source":"## 2. Fuzzy Choquet Integral — Core Implementation\n\nToàn bộ logic FCI được nhúng trực tiếp, chỉ dùng `numpy` + `scipy.optimize`.","metadata":{}},{"id":"e57070c4","cell_type":"code","source":"# ═══════════════════════════════════════════════════════════════════════════════\n# FUZZY CHOQUET INTEGRAL — Self-contained implementation\n# Chỉ dùng numpy + scipy.optimize (không cần pip install thêm)\n#\n# Lý thuyết:\n#   C_mu(f) = sum_{i=1}^{n} [f_σ(i) - f_σ(i-1)] * μ(A_σ(i))\n#   Trong đó σ là hoán vị sắp xếp f tăng dần,\n#   A_σ(i) = {σ(i), σ(i+1), ..., σ(n-1)} là tập hợp con từ i đến cuối.\n#\n# Học μ bằng L-BFGS-B tối thiểu CrossEntropy + Monotonicity Penalty.\n# ═══════════════════════════════════════════════════════════════════════════════\n\n# ── 1. Fuzzy Measure storage ─────────────────────────────────────────────────\nclass FuzzyMeasure:\n    \"\"\"Lưu và quản lý Fuzzy Measure μ(A) cho n nguồn.\"\"\"\n    def __init__(self, n: int):\n        self.n = n\n        self._mu: Dict[Tuple, float] = {}\n        # Khởi tạo symmetric: μ(A) = |A|/n\n        for r in range(1, n+1):\n            for s in itertools.combinations(range(n), r):\n                self._mu[s] = len(s) / n\n\n    def get(self, s: Tuple) -> float:\n        return 0.0 if not s else self._mu.get(tuple(sorted(s)), len(s)/self.n)\n\n    def set(self, s: Tuple, v: float):\n        self._mu[tuple(sorted(s))] = float(np.clip(v, 0.0, 1.0))\n\n    @property\n    def subsets(self):\n        return sorted(self._mu.keys(), key=lambda s: (len(s), s))\n\n    def from_vec(self, v: np.ndarray):\n        for k, s in enumerate(self.subsets):\n            if k < len(v): self.set(s, float(v[k]))\n\n    def to_vec(self) -> np.ndarray:\n        return np.array([self.get(s) for s in self.subsets])\n\n    def enforce_monotone(self):\n        for s in sorted(self._mu, key=len):\n            for e in range(self.n):\n                if e not in s:\n                    bigger = tuple(sorted(s + (e,)))\n                    if bigger in self._mu:\n                        self._mu[bigger] = max(self._mu[bigger], self.get(s))\n        self._mu[tuple(range(self.n))] = 1.0\n\n\n# ── 2. Choquet Integral computation ─────────────────────────────────────────\ndef _choquet_single(scores: np.ndarray, mu: FuzzyMeasure) -> float:\n    sigma = np.argsort(scores)\n    s_sorted = scores[sigma]\n    result = 0.0\n    for i in range(len(scores)):\n        a = tuple(sorted(sigma[i:].tolist()))\n        f_prev = 0.0 if i == 0 else float(s_sorted[i-1])\n        result += (float(s_sorted[i]) - f_prev) * mu.get(a)\n    return result\n\ndef choquet_batch(proba_3d: np.ndarray, mu: FuzzyMeasure) -> np.ndarray:\n    \"\"\"proba_3d: (N, S, C) → (N, C)\"\"\"\n    N, S, C = proba_3d.shape\n    out = np.zeros((N, C))\n    for c in range(C):\n        for i in range(N):\n            out[i, c] = _choquet_single(proba_3d[i, :, c], mu)\n    rs = out.sum(1, keepdims=True)\n    return out / np.where(rs == 0, 1.0, rs)\n\n\n# ── 3. Learn fuzzy measure ───────────────────────────────────────────────────\ndef _loss_fn(params, proba_3d, y_true, mu, lam=0.1):\n    sig = 1 / (1 + np.exp(-params))\n    mu.from_vec(sig)\n    mu.set(tuple(range(mu.n)), 1.0)\n    fused = np.clip(choquet_batch(proba_3d, mu), 1e-9, 1.0)\n    ce = -np.mean(np.log(fused[np.arange(len(y_true)), y_true.astype(int)]))\n    pen = 0.0\n    for s in mu.subsets:\n        for e in range(mu.n):\n            if e not in s:\n                bigger = tuple(sorted(s + (e,)))\n                diff = mu.get(s) - mu.get(bigger)\n                if diff > 0: pen += diff**2\n    return ce + lam * pen\n\ndef learn_measure(proba_3d, y_true, n_sources, max_iter=500, lam=0.1, verbose=True):\n    mu = FuzzyMeasure(n_sources)\n    v0 = mu.to_vec()\n    p0 = np.log(v0 / np.clip(1 - v0, 1e-9, 1.0))\n    if verbose: print(f\"[FCI] Tối ưu {len(p0)} tham số, max_iter={max_iter}...\")\n    res = minimize(_loss_fn, p0, args=(proba_3d, y_true, mu, lam),\n                   method='L-BFGS-B', options={'maxiter': max_iter,'ftol':1e-8,'gtol':1e-6})\n    sig = 1 / (1 + np.exp(-res.x))\n    mu.from_vec(sig)\n    mu.set(tuple(range(n_sources)), 1.0)\n    mu.enforce_monotone()\n    if verbose: print(f\"[FCI] Loss={res.fun:.6f}, converged={res.success}\")\n    return mu\n\n\n# ── 4. Shapley values ────────────────────────────────────────────────────────\ndef shapley(mu: FuzzyMeasure, i: int) -> float:\n    n = mu.n\n    others = [j for j in range(n) if j != i]\n    sv = 0.0\n    for r in range(n):\n        for combo in itertools.combinations(others, r):\n            s = tuple(sorted(combo))\n            s_i = tuple(sorted(combo + (i,)))\n            coeff = (math.factorial(len(s)) * math.factorial(n - len(s) - 1)\n                     / math.factorial(n))\n            sv += coeff * (mu.get(s_i) - mu.get(s))\n    return sv\n\n\n# ── 5. Ensemble class ────────────────────────────────────────────────────────\nclass FuzzyChoquetEnsemble:\n    def __init__(self, model_names: List[str], n_classes: int = 3,\n                 max_iter: int = 500, lam: float = 0.1):\n        self.model_names = model_names\n        self.n = len(model_names)\n        self.n_classes = n_classes\n        self.max_iter = max_iter\n        self.lam = lam\n        self.mu: Optional[FuzzyMeasure] = None\n\n    def fit(self, val_probas: List[np.ndarray], y_val: np.ndarray):\n        p3d = np.stack(val_probas, axis=1)   # (N, S, C)\n        self.mu = learn_measure(p3d, y_val, self.n, self.max_iter, self.lam)\n        self._shapley = {nm: shapley(self.mu, i) for i, nm in enumerate(self.model_names)}\n        print(\"\\nShapley Values:\")\n        for nm, sv in sorted(self._shapley.items(), key=lambda x: -x[1]):\n            print(f\"  {nm:30s}: {sv:.4f}\")\n        return self\n\n    def predict_proba(self, probas: List[np.ndarray]) -> np.ndarray:\n        return choquet_batch(np.stack(probas, axis=1), self.mu)\n\n    def predict(self, probas: List[np.ndarray]) -> np.ndarray:\n        return np.argmax(self.predict_proba(probas), axis=1)\n\n    def evaluate(self, probas, y_true, split='Test') -> dict:\n        fp = self.predict_proba(probas)\n        yp = np.argmax(fp, axis=1)\n        acc = accuracy_score(y_true, yp)\n        f1m = f1_score(y_true, yp, average='macro', zero_division=0)\n        f1w = f1_score(y_true, yp, average='weighted', zero_division=0)\n        qwk = cohen_kappa_score(y_true, yp, weights='quadratic')\n        prec_w = precision_score(y_true, yp, average='weighted', zero_division=0)\n        rec_w  = recall_score(y_true, yp, average='weighted', zero_division=0)\n        try:\n            yb = label_binarize(y_true, classes=list(range(self.n_classes)))\n            auc = roc_auc_score(yb, fp, average='weighted', multi_class='ovr')\n        except Exception: auc = float('nan')\n        print(f\"\\n[{split}] Acc={acc:.4f}  MacroF1={f1m:.4f}  WtF1={f1w:.4f}  AUC={auc:.4f}  QWK={qwk:.4f}\")\n        return {'Split':split,'Accuracy':acc,'Precision_Weighted':prec_w,\n                'Recall_Weighted':rec_w,'Macro_F1':f1m,\n                'Weighted_F1':f1w,'AUC':auc,'QWK':qwk}\n\n    def get_shapley(self): return self._shapley\n\nprint(\"[OK] Fuzzy Choquet Integral module loaded (numpy + scipy only).\")\n","metadata":{"execution":{"iopub.status.busy":"2026-05-21T05:32:46.121258Z","iopub.execute_input":"2026-05-21T05:32:46.121672Z","iopub.status.idle":"2026-05-21T05:32:46.156370Z","shell.execute_reply.started":"2026-05-21T05:32:46.121632Z","shell.execute_reply":"2026-05-21T05:32:46.155171Z"},"trusted":true},"outputs":[{"name":"stdout","text":"[OK] Fuzzy Choquet Integral module loaded (numpy + scipy only).\n","output_type":"stream"}],"execution_count":37},{"id":"9352e7e7","cell_type":"markdown","source":"## 3. Tải Dữ liệu","metadata":{}},{"id":"46715fb8","cell_type":"code","source":"# ── Tải dữ liệu train / val / test ─────────────────────────────────────────\ndef _resolve(*candidates):\n    for c in candidates:\n        p = Path(c) if Path(c).is_absolute() else PROJECT_ROOT / c\n        if p.exists(): return p\n    raise FileNotFoundError(f\"Không tìm thấy: {candidates[0]}\")\n\nTRAIN_PATH = _resolve(\n    '/kaggle/input/datasets/tailength/corporate-credit-rating/test/train.csv',\n    'data/processed/test/train.csv',\n    'data/processed/train_augmented_timegan.csv',\n)\nVAL_PATH = _resolve(\n    '/kaggle/input/datasets/tailength/corporate-credit-rating/test/val.csv',\n    'data/processed/test/val.csv',\n)\nTEST_PATH = _resolve(\n    '/kaggle/input/datasets/tailength/corporate-credit-rating/test/test.csv',\n    'data/processed/test/test.csv',\n)\n\ndf_train = pd.read_csv(TRAIN_PATH)\ndf_val   = pd.read_csv(VAL_PATH)\ndf_test  = pd.read_csv(TEST_PATH)\nprint(f\"Train: {df_train.shape}  Val: {df_val.shape}  Test: {df_test.shape}\")\n\nTARGET_COL = 'rating_detail'\nle = LabelEncoder().fit(df_train[TARGET_COL].astype(str))\ny_train = le.transform(df_train[TARGET_COL].astype(str))\nn_classes   = len(le.classes_)\nclass_names = list(le.classes_)\nMODEL_KEYS   = ['tBiLSTM', 'tcn', 'xgboost']\nMODEL_NAMES  = ['Transformer-BiLSTM', 'TCN', 'XGBoost']\nART_MAP = {'tBiLSTM':'transformer_bilstm','tcn':'tcn','xgboost':'xgboost',\n           'lstm':'lstm','patchtst':'patchtst','lgbm':'lightgbm'}\n# ── Load y_val / y_test aligned with proba .npy files ──────────────\n# Proba files are generated in DataLoader order (ticker-grouped, date-sorted),\n# NOT in CSV row order. We must use the y_val/y_test that were saved\n# alongside the probas to ensure row alignment.\n_ref_model_key = ART_MAP[MODEL_KEYS[0]]\n_y_val_path  = PROBA_INPUT_DIR / f'{_ref_model_key}_y_val.npy'\n_y_test_path = PROBA_INPUT_DIR / f'{_ref_model_key}_y_test.npy'\n\nif _y_val_path.exists() and _y_test_path.exists():\n    y_val  = np.load(str(_y_val_path)).astype(int)\n    y_test = np.load(str(_y_test_path)).astype(int)\n    print(f'[OK] Loaded aligned y_val from {_y_val_path.name} ({len(y_val)} rows)')\n    print(f'[OK] Loaded aligned y_test from {_y_test_path.name} ({len(y_test)} rows)')\nelse:\n    # Fallback to CSV-based labels (will work only if probas are also CSV-ordered)\n    y_val  = le.transform(df_val[TARGET_COL].astype(str))\n    y_test = le.transform(df_test[TARGET_COL].astype(str))\n    print('[WARN] Aligned y_val/y_test .npy not found, using CSV-order labels.')\n    print('       This may cause row misalignment with proba files!')\n\nnp.save(str(ARTIFACT_DIR/'y_val.npy'),  y_val)\nnp.save(str(ARTIFACT_DIR/'y_test.npy'), y_test)\n\nprint(f\"Classes: {class_names}  n={n_classes}\")\nprint(f\"Train y: {np.bincount(y_train)}\")\nprint(f\"Val   y: {np.bincount(y_val)}\")\nprint(f\"Test  y: {np.bincount(y_test)}\")\n","metadata":{"execution":{"iopub.status.busy":"2026-05-21T05:32:46.295012Z","iopub.execute_input":"2026-05-21T05:32:46.295362Z","iopub.status.idle":"2026-05-21T05:32:46.379967Z","shell.execute_reply.started":"2026-05-21T05:32:46.295299Z","shell.execute_reply":"2026-05-21T05:32:46.378911Z"},"trusted":true},"outputs":[{"name":"stdout","text":"Train: (6029, 20)  Val: (862, 20)  Test: (1723, 20)\n[OK] Loaded aligned y_val from transformer_bilstm_y_val.npy (862 rows)\n[OK] Loaded aligned y_test from transformer_bilstm_y_test.npy (1723 rows)\nClasses: ['0', '1', '2']  n=3\nTrain y: [ 207 1957 3865]\nVal   y: [0 0 0 ... 1 1 1]\nTest  y: [0 0 0 ... 1 1 1]\n","output_type":"stream"}],"execution_count":38},{"id":"fbb1c32e","cell_type":"markdown","source":"## 4. OOF Probabilities từ Baseline Notebooks","metadata":{}},{"id":"bce260df","cell_type":"markdown","source":"## Lưu ý: OOF Probabilities từ Baseline Notebooks\n\nNotebook này đọc file `.npy` đã lưu từ 6 notebook baseline.\n**Cách lưu**: Thêm cell sau vào **cuối** mỗi notebook baseline sau khi training xong:\n\n```python\nMODEL_KEY = 'transformer_bilstm'  # tcn | xgboost | lstm | patchtst | lightgbm\n# Deep learning:  val_proba, test_proba đã có sẵn sau training loop\n# Tree-based:     val_proba = model.predict_proba(X_val)\n#                 test_proba = model.predict_proba(X_test)\nnp.save(str(ARTIFACT_DIR / f'{MODEL_KEY}_val_proba.npy'),  val_proba.astype(np.float32))\nnp.save(str(ARTIFACT_DIR / f'{MODEL_KEY}_test_proba.npy'), test_proba.astype(np.float32))\nprint(\"OOF saved to\", ARTIFACT_DIR)\n```\n","metadata":{}},{"id":"2d72812a","cell_type":"code","source":"\n\nval_probas, test_probas, missing = [], [], []\n\nfor key in MODEL_KEYS:\n    art = ART_MAP.get(key, key)\n    vp_path = PROBA_INPUT_DIR / f'{art}_val_proba.npy'\n    tp_path = PROBA_INPUT_DIR / f'{art}_test_proba.npy'\n    if vp_path.exists() and tp_path.exists():\n        vp = np.load(str(vp_path)).astype(np.float64)\n        tp = np.load(str(tp_path)).astype(np.float64)\n        print(f\"  [OK] {key}: val={vp.shape}, test={tp.shape}\")\n    else:\n        missing.append(key)\n        vp = np.full((len(y_val),  n_classes), 1.0/n_classes)\n        tp = np.full((len(y_test), n_classes), 1.0/n_classes)\n        print(f\"  [WARN] {key}: file không tìm thấy, dùng uniform proba fallback\")\n    val_probas.append(vp)\n    test_probas.append(tp)\n\nif missing:\n    print(f\"\\n[WARN] Thiếu OOF cho: {missing}\")\n    print(\"  --> Chạy và export OOF từ notebook baseline trước.\")\nelse:\n    print(f\"\\n[OK] Đã tải đủ {len(MODEL_KEYS)} mô hình.\")\n","metadata":{"execution":{"iopub.status.busy":"2026-05-21T05:32:46.382166Z","iopub.execute_input":"2026-05-21T05:32:46.382519Z","iopub.status.idle":"2026-05-21T05:32:46.401636Z","shell.execute_reply.started":"2026-05-21T05:32:46.382482Z","shell.execute_reply":"2026-05-21T05:32:46.400238Z"},"trusted":true},"outputs":[{"name":"stdout","text":"  [OK] tBiLSTM: val=(862, 3), test=(1723, 3)\n  [OK] tcn: val=(862, 3), test=(1723, 3)\n  [OK] xgboost: val=(862, 3), test=(1723, 3)\n\n[OK] Đã tải đủ 3 mô hình.\n","output_type":"stream"}],"execution_count":39},{"id":"3ce7de94-8d34-4829-beda-4122b07a8d55","cell_type":"markdown","source":"## 5. Học Fuzzy Measure (Fit Ensemble)","metadata":{}},{"id":"ee875d11-9f52-4c7b-8d5b-1e1f0f9e145c","cell_type":"code","source":"print(\"=\" * 65)\nprint(\"Kịch bản: Kịch bản 7: FI-TTX — Fuzzy Choquet Integral Ensemble\")\nprint(\"Mô hình :\", MODEL_NAMES)\nprint(\"=\" * 65)\n\nens = FuzzyChoquetEnsemble(\n    model_names = MODEL_NAMES,\n    n_classes   = n_classes,\n    max_iter    = 600,\n    lam         = 0.1,\n)\nens.fit(val_probas, y_val)\n","metadata":{"execution":{"iopub.status.busy":"2026-05-21T05:32:46.403260Z","iopub.execute_input":"2026-05-21T05:32:46.403703Z","iopub.status.idle":"2026-05-21T05:32:46.452584Z","shell.execute_reply.started":"2026-05-21T05:32:46.403661Z","shell.execute_reply":"2026-05-21T05:32:46.450605Z"},"trusted":true},"outputs":[{"name":"stdout","text":"=================================================================\nKịch bản: Kịch bản 7: FI-TTX — Fuzzy Choquet Integral Ensemble\nMô hình : ['Transformer-BiLSTM', 'TCN', 'XGBoost']\n=================================================================\n[FCI] Tối ưu 7 tham số, max_iter=6087...\n","output_type":"stream"},{"traceback":["\u001b[0;31m---------------------------------------------------------------------------\u001b[0m","\u001b[0;31mIndexError\u001b[0m                                Traceback (most recent call last)","\u001b[0;32m/tmp/ipykernel_57/3272005447.py\u001b[0m in \u001b[0;36m<cell line: 0>\u001b[0;34m()\u001b[0m\n\u001b[1;32m     10\u001b[0m     \u001b[0mlam\u001b[0m         \u001b[0;34m=\u001b[0m \u001b[0;36m0.1\u001b[0m\u001b[0;34m,\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n\u001b[1;32m     11\u001b[0m )\n\u001b[0;32m---> 12\u001b[0;31m \u001b[0mens\u001b[0m\u001b[0;34m.\u001b[0m\u001b[0mfit\u001b[0m\u001b[0;34m(\u001b[0m\u001b[0mval_probas\u001b[0m\u001b[0;34m,\u001b[0m \u001b[0my_val\u001b[0m\u001b[0;34m)\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n\u001b[0m","\u001b[0;32m/tmp/ipykernel_57/2996159221.py\u001b[0m in \u001b[0;36mfit\u001b[0;34m(self, val_probas, y_val)\u001b[0m\n\u001b[1;32m    130\u001b[0m     \u001b[0;32mdef\u001b[0m \u001b[0mfit\u001b[0m\u001b[0;34m(\u001b[0m\u001b[0mself\u001b[0m\u001b[0;34m,\u001b[0m \u001b[0mval_probas\u001b[0m\u001b[0;34m:\u001b[0m \u001b[0mList\u001b[0m\u001b[0;34m[\u001b[0m\u001b[0mnp\u001b[0m\u001b[0;34m.\u001b[0m\u001b[0mndarray\u001b[0m\u001b[0;34m]\u001b[0m\u001b[0;34m,\u001b[0m \u001b[0my_val\u001b[0m\u001b[0;34m:\u001b[0m \u001b[0mnp\u001b[0m\u001b[0;34m.\u001b[0m\u001b[0mndarray\u001b[0m\u001b[0;34m)\u001b[0m\u001b[0;34m:\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n\u001b[1;32m    131\u001b[0m         \u001b[0mp3d\u001b[0m \u001b[0;34m=\u001b[0m \u001b[0mnp\u001b[0m\u001b[0;34m.\u001b[0m\u001b[0mstack\u001b[0m\u001b[0;34m(\u001b[0m\u001b[0mval_probas\u001b[0m\u001b[0;34m,\u001b[0m \u001b[0maxis\u001b[0m\u001b[0;34m=\u001b[0m\u001b[0;36m1\u001b[0m\u001b[0;34m)\u001b[0m   \u001b[0;31m# (N, S, C)\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n\u001b[0;32m--> 132\u001b[0;31m         \u001b[0mself\u001b[0m\u001b[0;34m.\u001b[0m\u001b[0mmu\u001b[0m \u001b[0;34m=\u001b[0m \u001b[0mlearn_measure\u001b[0m\u001b[0;34m(\u001b[0m\u001b[0mp3d\u001b[0m\u001b[0;34m,\u001b[0m \u001b[0my_val\u001b[0m\u001b[0;34m,\u001b[0m \u001b[0mself\u001b[0m\u001b[0;34m.\u001b[0m\u001b[0mn\u001b[0m\u001b[0;34m,\u001b[0m \u001b[0mself\u001b[0m\u001b[0;34m.\u001b[0m\u001b[0mmax_iter\u001b[0m\u001b[0;34m,\u001b[0m \u001b[0mself\u001b[0m\u001b[0;34m.\u001b[0m\u001b[0mlam\u001b[0m\u001b[0;34m)\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n\u001b[0m\u001b[1;32m    133\u001b[0m         \u001b[0mself\u001b[0m\u001b[0;34m.\u001b[0m\u001b[0m_shapley\u001b[0m \u001b[0;34m=\u001b[0m \u001b[0;34m{\u001b[0m\u001b[0mnm\u001b[0m\u001b[0;34m:\u001b[0m \u001b[0mshapley\u001b[0m\u001b[0;34m(\u001b[0m\u001b[0mself\u001b[0m\u001b[0;34m.\u001b[0m\u001b[0mmu\u001b[0m\u001b[0;34m,\u001b[0m \u001b[0mi\u001b[0m\u001b[0;34m)\u001b[0m \u001b[0;32mfor\u001b[0m \u001b[0mi\u001b[0m\u001b[0;34m,\u001b[0m \u001b[0mnm\u001b[0m \u001b[0;32min\u001b[0m \u001b[0menumerate\u001b[0m\u001b[0;34m(\u001b[0m\u001b[0mself\u001b[0m\u001b[0;34m.\u001b[0m\u001b[0mmodel_names\u001b[0m\u001b[0;34m)\u001b[0m\u001b[0;34m}\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n\u001b[1;32m    134\u001b[0m         \u001b[0mprint\u001b[0m\u001b[0;34m(\u001b[0m\u001b[0;34m\"\\nShapley Values:\"\u001b[0m\u001b[0;34m)\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n","\u001b[0;32m/tmp/ipykernel_57/2996159221.py\u001b[0m in \u001b[0;36mlearn_measure\u001b[0;34m(proba_3d, y_true, n_sources, max_iter, lam, verbose)\u001b[0m\n\u001b[1;32m     92\u001b[0m     \u001b[0mp0\u001b[0m \u001b[0;34m=\u001b[0m \u001b[0mnp\u001b[0m\u001b[0;34m.\u001b[0m\u001b[0mlog\u001b[0m\u001b[0;34m(\u001b[0m\u001b[0mv0\u001b[0m \u001b[0;34m/\u001b[0m \u001b[0mnp\u001b[0m\u001b[0;34m.\u001b[0m\u001b[0mclip\u001b[0m\u001b[0;34m(\u001b[0m\u001b[0;36m1\u001b[0m \u001b[0;34m-\u001b[0m \u001b[0mv0\u001b[0m\u001b[0;34m,\u001b[0m \u001b[0;36m1e-9\u001b[0m\u001b[0;34m,\u001b[0m \u001b[0;36m1.0\u001b[0m\u001b[0;34m)\u001b[0m\u001b[0;34m)\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n\u001b[1;32m     93\u001b[0m     \u001b[0;32mif\u001b[0m \u001b[0mverbose\u001b[0m\u001b[0;34m:\u001b[0m \u001b[0mprint\u001b[0m\u001b[0;34m(\u001b[0m\u001b[0;34mf\"[FCI] Tối ưu {len(p0)} tham số, max_iter={max_iter}...\"\u001b[0m\u001b[0;34m)\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n\u001b[0;32m---> 94\u001b[0;31m     res = minimize(_loss_fn, p0, args=(proba_3d, y_true, mu, lam),\n\u001b[0m\u001b[1;32m     95\u001b[0m                    method='L-BFGS-B', options={'maxiter': max_iter,'ftol':1e-8,'gtol':1e-6})\n\u001b[1;32m     96\u001b[0m     \u001b[0msig\u001b[0m \u001b[0;34m=\u001b[0m \u001b[0;36m1\u001b[0m \u001b[0;34m/\u001b[0m \u001b[0;34m(\u001b[0m\u001b[0;36m1\u001b[0m \u001b[0;34m+\u001b[0m \u001b[0mnp\u001b[0m\u001b[0;34m.\u001b[0m\u001b[0mexp\u001b[0m\u001b[0;34m(\u001b[0m\u001b[0;34m-\u001b[0m\u001b[0mres\u001b[0m\u001b[0;34m.\u001b[0m\u001b[0mx\u001b[0m\u001b[0;34m)\u001b[0m\u001b[0;34m)\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n","\u001b[0;32m/usr/local/lib/python3.12/dist-packages/scipy/optimize/_minimize.py\u001b[0m in \u001b[0;36mminimize\u001b[0;34m(fun, x0, args, method, jac, hess, hessp, bounds, constraints, tol, callback, options)\u001b[0m\n\u001b[1;32m    782\u001b[0m                                  **options)\n\u001b[1;32m    783\u001b[0m     \u001b[0;32melif\u001b[0m \u001b[0mmeth\u001b[0m \u001b[0;34m==\u001b[0m \u001b[0;34m'l-bfgs-b'\u001b[0m\u001b[0;34m:\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n\u001b[0;32m--> 784\u001b[0;31m         res = _minimize_lbfgsb(fun, x0, args, jac, bounds,\n\u001b[0m\u001b[1;32m    785\u001b[0m                                callback=callback, **options)\n\u001b[1;32m    786\u001b[0m     \u001b[0;32melif\u001b[0m \u001b[0mmeth\u001b[0m \u001b[0;34m==\u001b[0m \u001b[0;34m'tnc'\u001b[0m\u001b[0;34m:\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n","\u001b[0;32m/usr/local/lib/python3.12/dist-packages/scipy/optimize/_lbfgsb_py.py\u001b[0m in \u001b[0;36m_minimize_lbfgsb\u001b[0;34m(fun, x0, args, jac, bounds, disp, maxcor, ftol, gtol, eps, maxfun, maxiter, iprint, callback, maxls, finite_diff_rel_step, workers, **unknown_options)\u001b[0m\n\u001b[1;32m    411\u001b[0m \u001b[0;34m\u001b[0m\u001b[0m\n\u001b[1;32m    412\u001b[0m     \u001b[0;31m# _prepare_scalar_function can use bounds=None to represent no bounds\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n\u001b[0;32m--> 413\u001b[0;31m     sf = _prepare_scalar_function(fun, x0, jac=jac, args=args, epsilon=eps,\n\u001b[0m\u001b[1;32m    414\u001b[0m                                   \u001b[0mbounds\u001b[0m\u001b[0;34m=\u001b[0m\u001b[0mbounds\u001b[0m\u001b[0;34m,\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n\u001b[1;32m    415\u001b[0m                                   \u001b[0mfinite_diff_rel_step\u001b[0m\u001b[0;34m=\u001b[0m\u001b[0mfinite_diff_rel_step\u001b[0m\u001b[0;34m,\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n","\u001b[0;32m/usr/local/lib/python3.12/dist-packages/scipy/optimize/_optimize.py\u001b[0m in \u001b[0;36m_prepare_scalar_function\u001b[0;34m(fun, x0, jac, args, bounds, epsilon, finite_diff_rel_step, hess, workers)\u001b[0m\n\u001b[1;32m    308\u001b[0m     \u001b[0;31m# ScalarFunction caches. Reuse of fun(x) during grad\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n\u001b[1;32m    309\u001b[0m     \u001b[0;31m# calculation reduces overall function evaluations.\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n\u001b[0;32m--> 310\u001b[0;31m     sf = ScalarFunction(fun, x0, args, grad, hess,\n\u001b[0m\u001b[1;32m    311\u001b[0m                         \u001b[0mfinite_diff_rel_step\u001b[0m\u001b[0;34m,\u001b[0m \u001b[0mbounds\u001b[0m\u001b[0;34m,\u001b[0m \u001b[0mepsilon\u001b[0m\u001b[0;34m=\u001b[0m\u001b[0mepsilon\u001b[0m\u001b[0;34m,\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n\u001b[1;32m    312\u001b[0m                         workers=workers)\n","\u001b[0;32m/usr/local/lib/python3.12/dist-packages/scipy/optimize/_differentiable_functions.py\u001b[0m in \u001b[0;36m__init__\u001b[0;34m(self, fun, x0, args, grad, hess, finite_diff_rel_step, finite_diff_bounds, epsilon, workers)\u001b[0m\n\u001b[1;32m    272\u001b[0m         \u001b[0;31m# Initial function evaluation\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n\u001b[1;32m    273\u001b[0m         \u001b[0mself\u001b[0m\u001b[0;34m.\u001b[0m\u001b[0m_nfev\u001b[0m \u001b[0;34m=\u001b[0m \u001b[0;36m0\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n\u001b[0;32m--> 274\u001b[0;31m         \u001b[0mself\u001b[0m\u001b[0;34m.\u001b[0m\u001b[0m_update_fun\u001b[0m\u001b[0;34m(\u001b[0m\u001b[0;34m)\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n\u001b[0m\u001b[1;32m    275\u001b[0m \u001b[0;34m\u001b[0m\u001b[0m\n\u001b[1;32m    276\u001b[0m         \u001b[0;31m# Initial gradient evaluation\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n","\u001b[0;32m/usr/local/lib/python3.12/dist-packages/scipy/optimize/_differentiable_functions.py\u001b[0m in \u001b[0;36m_update_fun\u001b[0;34m(self)\u001b[0m\n\u001b[1;32m    351\u001b[0m     \u001b[0;32mdef\u001b[0m \u001b[0m_update_fun\u001b[0m\u001b[0;34m(\u001b[0m\u001b[0mself\u001b[0m\u001b[0;34m)\u001b[0m\u001b[0;34m:\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n\u001b[1;32m    352\u001b[0m         \u001b[0;32mif\u001b[0m \u001b[0;32mnot\u001b[0m \u001b[0mself\u001b[0m\u001b[0;34m.\u001b[0m\u001b[0mf_updated\u001b[0m\u001b[0;34m:\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n\u001b[0;32m--> 353\u001b[0;31m             \u001b[0mfx\u001b[0m \u001b[0;34m=\u001b[0m \u001b[0mself\u001b[0m\u001b[0;34m.\u001b[0m\u001b[0m_wrapped_fun\u001b[0m\u001b[0;34m(\u001b[0m\u001b[0mself\u001b[0m\u001b[0;34m.\u001b[0m\u001b[0mx\u001b[0m\u001b[0;34m)\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n\u001b[0m\u001b[1;32m    354\u001b[0m             \u001b[0mself\u001b[0m\u001b[0;34m.\u001b[0m\u001b[0m_nfev\u001b[0m \u001b[0;34m+=\u001b[0m \u001b[0;36m1\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n\u001b[1;32m    355\u001b[0m             \u001b[0;32mif\u001b[0m \u001b[0mfx\u001b[0m \u001b[0;34m<\u001b[0m \u001b[0mself\u001b[0m\u001b[0;34m.\u001b[0m\u001b[0m_lowest_f\u001b[0m\u001b[0;34m:\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n","\u001b[0;32m/usr/local/lib/python3.12/dist-packages/scipy/_lib/_util.py\u001b[0m in \u001b[0;36m__call__\u001b[0;34m(self, x)\u001b[0m\n\u001b[1;32m    588\u001b[0m         \u001b[0;31m# Send a copy because the user may overwrite it.\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n\u001b[1;32m    589\u001b[0m         \u001b[0;31m# The user of this class might want `x` to remain unchanged.\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n\u001b[0;32m--> 590\u001b[0;31m         \u001b[0mfx\u001b[0m \u001b[0;34m=\u001b[0m \u001b[0mself\u001b[0m\u001b[0;34m.\u001b[0m\u001b[0mf\u001b[0m\u001b[0;34m(\u001b[0m\u001b[0mnp\u001b[0m\u001b[0;34m.\u001b[0m\u001b[0mcopy\u001b[0m\u001b[0;34m(\u001b[0m\u001b[0mx\u001b[0m\u001b[0;34m)\u001b[0m\u001b[0;34m,\u001b[0m \u001b[0;34m*\u001b[0m\u001b[0mself\u001b[0m\u001b[0;34m.\u001b[0m\u001b[0margs\u001b[0m\u001b[0;34m)\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n\u001b[0m\u001b[1;32m    591\u001b[0m         \u001b[0mself\u001b[0m\u001b[0;34m.\u001b[0m\u001b[0mnfev\u001b[0m \u001b[0;34m+=\u001b[0m \u001b[0;36m1\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n\u001b[1;32m    592\u001b[0m \u001b[0;34m\u001b[0m\u001b[0m\n","\u001b[0;32m/tmp/ipykernel_57/2996159221.py\u001b[0m in \u001b[0;36m_loss_fn\u001b[0;34m(params, proba_3d, y_true, mu, lam)\u001b[0m\n\u001b[1;32m     77\u001b[0m     \u001b[0mmu\u001b[0m\u001b[0;34m.\u001b[0m\u001b[0mset\u001b[0m\u001b[0;34m(\u001b[0m\u001b[0mtuple\u001b[0m\u001b[0;34m(\u001b[0m\u001b[0mrange\u001b[0m\u001b[0;34m(\u001b[0m\u001b[0mmu\u001b[0m\u001b[0;34m.\u001b[0m\u001b[0mn\u001b[0m\u001b[0;34m)\u001b[0m\u001b[0;34m)\u001b[0m\u001b[0;34m,\u001b[0m \u001b[0;36m1.0\u001b[0m\u001b[0;34m)\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n\u001b[1;32m     78\u001b[0m     \u001b[0mfused\u001b[0m \u001b[0;34m=\u001b[0m \u001b[0mnp\u001b[0m\u001b[0;34m.\u001b[0m\u001b[0mclip\u001b[0m\u001b[0;34m(\u001b[0m\u001b[0mchoquet_batch\u001b[0m\u001b[0;34m(\u001b[0m\u001b[0mproba_3d\u001b[0m\u001b[0;34m,\u001b[0m \u001b[0mmu\u001b[0m\u001b[0;34m)\u001b[0m\u001b[0;34m,\u001b[0m \u001b[0;36m1e-9\u001b[0m\u001b[0;34m,\u001b[0m \u001b[0;36m1.0\u001b[0m\u001b[0;34m)\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n\u001b[0;32m---> 79\u001b[0;31m     \u001b[0mce\u001b[0m \u001b[0;34m=\u001b[0m \u001b[0;34m-\u001b[0m\u001b[0mnp\u001b[0m\u001b[0;34m.\u001b[0m\u001b[0mmean\u001b[0m\u001b[0;34m(\u001b[0m\u001b[0mnp\u001b[0m\u001b[0;34m.\u001b[0m\u001b[0mlog\u001b[0m\u001b[0;34m(\u001b[0m\u001b[0mfused\u001b[0m\u001b[0;34m[\u001b[0m\u001b[0mnp\u001b[0m\u001b[0;34m.\u001b[0m\u001b[0marange\u001b[0m\u001b[0;34m(\u001b[0m\u001b[0mlen\u001b[0m\u001b[0;34m(\u001b[0m\u001b[0my_true\u001b[0m\u001b[0;34m)\u001b[0m\u001b[0;34m)\u001b[0m\u001b[0;34m,\u001b[0m \u001b[0my_true\u001b[0m\u001b[0;34m.\u001b[0m\u001b[0mastype\u001b[0m\u001b[0;34m(\u001b[0m\u001b[0mint\u001b[0m\u001b[0;34m)\u001b[0m\u001b[0;34m]\u001b[0m\u001b[0;34m)\u001b[0m\u001b[0;34m)\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n\u001b[0m\u001b[1;32m     80\u001b[0m     \u001b[0mpen\u001b[0m \u001b[0;34m=\u001b[0m \u001b[0;36m0.0\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n\u001b[1;32m     81\u001b[0m     \u001b[0;32mfor\u001b[0m \u001b[0ms\u001b[0m \u001b[0;32min\u001b[0m \u001b[0mmu\u001b[0m\u001b[0;34m.\u001b[0m\u001b[0msubsets\u001b[0m\u001b[0;34m:\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n","\u001b[0;31mIndexError\u001b[0m: index 6087 is out of bounds for axis 1 with size 3"],"ename":"IndexError","evalue":"index 6087 is out of bounds for axis 1 with size 3","output_type":"error"}],"execution_count":40},{"id":"0797c15e-25ef-4ccd-ba6e-b2c333619b1c","cell_type":"markdown","source":"## 6. Đánh giá Val & Test","metadata":{}},{"id":"bc23dad2","cell_type":"code","source":"import time\nfrom sklearn.metrics import roc_curve, auc\n\n# ── Inference Time Measurement ───────────────────────────────────────────────\nstart_time = time.time()\nfp     = ens.predict_proba(test_probas)\ny_pred = np.argmax(fp, axis=1)\nend_time = time.time()\nelapsed_time = end_time - start_time\nprint(f\"Test Inference/Evaluation Time: {elapsed_time:.6f} seconds\")\n\nval_metrics  = ens.evaluate(val_probas,  y_val,  split='Val')\ntest_metrics = ens.evaluate(test_probas, y_test, split='Test')\n\n# ── Confusion Matrix ────────────────────────────────────────────────────────\ncm = confusion_matrix(y_test, y_pred)\ncm_df = pd.DataFrame(cm, index=class_names, columns=class_names)\n\nfig, ax = plt.subplots(figsize=(6,5), dpi=150)\nsns.heatmap(cm_df, annot=True, fmt='d', cmap='Blues', cbar=False, ax=ax)\nax.set_title('Kịch bản 7: FI-TTX — Fuzzy Choquet Integral Ensemble\\nFuzzy Choquet Integral — Confusion Matrix (Test)', fontweight='bold')\nax.set_xlabel('Predicted'); ax.set_ylabel('True')\nplt.tight_layout()\nplt.savefig(ARTIFACT_DIR/'fi_ttx_cm.png', dpi=300, bbox_inches='tight')\nplt.show()\n\nprint(\"\\nClassification Report (Test):\")\nprint(classification_report(y_test, y_pred, target_names=class_names, digits=4, zero_division=0))\n\n# ── AUC-ROC Plot ────────────────────────────────────────────────────────────\nplt.figure(figsize=(10, 8))\ny_test_bin = label_binarize(y_test, classes=list(range(n_classes)))\n\nfor i in range(n_classes):\n    fpr_class, tpr_class, _ = roc_curve(y_test_bin[:, i], fp[:, i])\n    roc_auc_val = auc(fpr_class, tpr_class)\n    plt.plot(fpr_class, tpr_class, lw=2, label=f'ROC curve of class {class_names[i]} (area = {roc_auc_val:0.2f})')\n\nplt.plot([0, 1], [0, 1], 'k--', lw=2)\nplt.xlim([0.0, 1.0])\nplt.ylim([0.0, 1.05])\nplt.xlabel('False Positive Rate')\nplt.ylabel('True Positive Rate')\nplt.title('Kịch bản 7: FI-TTX - Receiver Operating Characteristic (ROC) - Multiclass')\nplt.legend(loc=\"lower right\")\nplt.grid(alpha=0.3)\nroc_plot_path = ARTIFACT_DIR / 'fi_ttx_roc.png'\nplt.savefig(roc_plot_path, dpi=300, bbox_inches='tight')\nplt.show()\nprint('Saved ROC curves to:', roc_plot_path)\n\n# ── Save metrics ─────────────────────────────────────────────────────────────\nmdf = pd.DataFrame([val_metrics, test_metrics])\nmdf.to_csv(ARTIFACT_DIR/'fi_ttx_metrics.csv', index=False)\nnp.save(str(ARTIFACT_DIR/'fi_ttx_test_proba.npy'), fp.astype(np.float32))\nnp.save(str(ARTIFACT_DIR/'fi_ttx_test_pred.npy'),  y_pred.astype(np.int32))\nprint(\"Saved metrics + predictions to\", ARTIFACT_DIR)\n","metadata":{"execution":{"iopub.status.busy":"2026-05-21T05:32:46.454442Z","iopub.status.idle":"2026-05-21T05:32:46.454979Z","shell.execute_reply.started":"2026-05-21T05:32:46.454723Z","shell.execute_reply":"2026-05-21T05:32:46.454752Z"},"trusted":true},"outputs":[],"execution_count":null},{"id":"1ac88365","cell_type":"markdown","source":"## 7. Visualize Shapley Values & Fuzzy Measure","metadata":{}},{"id":"25f1845a","cell_type":"code","source":"# ── Shapley Value Bar Chart ─────────────────────────────────────────────────\nsv = ens.get_shapley()\nnames_sv = list(sv.keys()); vals_sv = [sv[n] for n in names_sv]\n\nfig, axes = plt.subplots(1, 2, figsize=(14, 5), dpi=150)\n\n# Bar: Shapley\ncolors = sns.color_palette(\"viridis\", len(names_sv))\naxes[0].barh(names_sv, vals_sv, color=colors)\nfor i,(nm,v) in enumerate(zip(names_sv,vals_sv)):\n    axes[0].text(v+0.001, i, f\"{v:.4f}\", va='center', fontsize=9)\naxes[0].set_xlabel(\"Shapley Value\")\naxes[0].set_title('Kịch bản 7: FI-TTX — Fuzzy Choquet Integral Ensemble\\nModel Importance (Shapley)', fontweight='bold')\n\n# Heatmap: pairwise fuzzy measure\nn_src = ens.n\nmat = np.zeros((n_src, n_src))\nfor i in range(n_src):\n    mat[i,i] = ens.mu.get((i,))\n    for j in range(i+1, n_src):\n        v = ens.mu.get((i,j))\n        mat[i,j] = mat[j,i] = v\n\nhdf = pd.DataFrame(mat, index=MODEL_NAMES, columns=MODEL_NAMES)\nsns.heatmap(hdf, annot=True, fmt='.3f', cmap='YlOrRd', ax=axes[1],\n            vmin=0, vmax=1, linewidths=0.5)\naxes[1].set_title('Fuzzy Measure μ(A) — Pairwise', fontweight='bold')\n\nplt.tight_layout()\nplt.savefig(ARTIFACT_DIR/'fi_ttx_shapley_heatmap.png', dpi=300, bbox_inches='tight')\nplt.show()\nprint(\"Saved:\", ARTIFACT_DIR/'fi_ttx_shapley_heatmap.png')\n","metadata":{"execution":{"iopub.status.busy":"2026-05-21T05:32:46.456155Z","iopub.status.idle":"2026-05-21T05:32:46.456606Z","shell.execute_reply.started":"2026-05-21T05:32:46.456427Z","shell.execute_reply":"2026-05-21T05:32:46.456451Z"},"trusted":true},"outputs":[],"execution_count":null},{"id":"009a04dd","cell_type":"markdown","source":"## xAI LIME Interpretation\n","metadata":{}},{"id":"e4af7948","cell_type":"code","source":"# ==============================================================================\n# xAI LIME Explainability\n# ==============================================================================\nLIME_ENABLED = True\n\nif LIME_ENABLED:\n    import subprocess\n\n    try:\n        import lime\n        import lime.lime_tabular\n    except ImportError:\n        print(\"Installing lime package...\")\n        subprocess.check_call([sys.executable, \"-m\", \"pip\", \"install\", \"lime\", \"-q\"])\n        import lime\n        import lime.lime_tabular\n\n    if 'ens' not in globals() or 'val_probas' not in globals() or 'test_probas' not in globals():\n        raise RuntimeError('Khong tim thay ens/val_probas/test_probas. Hay chay cell huan luyen truoc.')\n\n    # Local class names\n    lime_class_names = class_names if 'class_names' in globals() else [str(i) for i in range(n_classes)]\n    \n    # Feature names: each feature is a specific class probability from a specific model\n    feature_names = [\n        f\"{model_name}__{cls}\"\n        for model_name in ens.model_names\n        for cls in lime_class_names\n    ]\n\n    # Stack and flatten validation probabilities for background explainer\n    val_probas_stacked = np.stack(val_probas, axis=1)  # (N_val, S, C)\n    val_probas_flat = val_probas_stacked.reshape(len(y_val), -1)  # (N_val, S * C)\n\n    # Stack and flatten test probabilities\n    test_probas_stacked = np.stack(test_probas, axis=1)  # (N_test, S, C)\n    test_probas_flat = test_probas_stacked.reshape(len(y_test), -1)  # (N_test, S * C)\n\n    # Custom predict_fn for LIME that takes flat probas and runs Choquet Fusion\n    def ensemble_predict_fn_lime(x_flat_batch):\n        x_flat_batch = np.asarray(x_flat_batch, dtype=np.float64)\n        if x_flat_batch.ndim == 1:\n            x_flat_batch = x_flat_batch.reshape(1, -1)\n        N_batch = x_flat_batch.shape[0]\n        # Reshape back to (N_batch, S, C)\n        p3d = x_flat_batch.reshape(N_batch, ens.n, ens.n_classes)\n        return choquet_batch(p3d, ens.mu)\n\n    # Initialize LimeTabularExplainer\n    explainer = lime.lime_tabular.LimeTabularExplainer(\n        training_data=val_probas_flat,\n        feature_names=feature_names,\n        class_names=lime_class_names,\n        mode='classification',\n        random_state=SEED if 'SEED' in globals() else 42\n    )\n\n    # Randomly select 3 samples to explain\n    rng = np.random.default_rng(SEED if 'SEED' in globals() else 42)\n    selected_indices = rng.choice(len(y_test), size=min(3, len(y_test)), replace=False)\n\n    print(f\"LIME explainability enabled. Explaining {len(selected_indices)} random ensemble predictions:\")\n    for idx in selected_indices:\n        print(f\"\\n--- Explaining ensemble prediction at test index {idx} ---\")\n        exp = explainer.explain_instance(\n            data_row=test_probas_flat[idx],\n            predict_fn=ensemble_predict_fn_lime,\n            num_features=10\n        )\n        # Show in notebook\n        try:\n            exp.show_in_notebook(show_table=True)\n        except Exception:\n            pass\n        \n        # Save HTML visualization\n        html_path = ARTIFACT_DIR / f\"ensemble_lime_explanation_test_idx_{idx}.html\"\n        exp.save_to_file(str(html_path))\n        print(f\"Saved LIME explanation HTML to: {html_path}\")\n        print(\"LIME Local Explanation Details:\")\n        for feature, weight in exp.as_list():\n            print(f\"  {feature:<30} : {weight:+.4f}\")\n","metadata":{"execution":{"iopub.status.busy":"2026-05-21T05:32:46.459372Z","iopub.status.idle":"2026-05-21T05:32:46.459910Z","shell.execute_reply.started":"2026-05-21T05:32:46.459687Z","shell.execute_reply":"2026-05-21T05:32:46.459717Z"},"trusted":true},"outputs":[],"execution_count":null},{"id":"062e96e4","cell_type":"markdown","source":"## xAI SHAP Interpretation\n","metadata":{}},{"id":"eb532a7a","cell_type":"code","source":"# ==============================================================================\n# xAI SHAP Explainability\n# ==============================================================================\nSHAP_ENABLED = True\n\nif SHAP_ENABLED:\n    import subprocess\n\n    try:\n        import shap\n    except ImportError:\n        print(\"Installing shap package...\")\n        subprocess.check_call([sys.executable, \"-m\", \"pip\", \"install\", \"shap\", \"-q\"])\n        import shap\n\n    if 'ens' not in globals() or 'val_probas' not in globals() or 'test_probas' not in globals():\n        raise RuntimeError('Khong tim thay ens/val_probas/test_probas. Hay chay cell huan luyen truoc.')\n\n    # Local class names\n    shap_class_names = class_names if 'class_names' in globals() else [str(i) for i in range(n_classes)]\n    \n    # Feature names: each feature is a specific class probability from a specific model\n    feature_names = [\n        f\"{model_name}__{cls}\"\n        for model_name in ens.model_names\n        for cls in shap_class_names\n    ]\n\n    # Stack and flatten validation probabilities for background explainer\n    val_probas_stacked = np.stack(val_probas, axis=1)  # (N_val, S, C)\n    val_probas_flat = val_probas_stacked.reshape(len(y_val), -1)  # (N_val, S * C)\n\n    # Stack and flatten test probabilities\n    test_probas_stacked = np.stack(test_probas, axis=1)  # (N_test, S, C)\n    test_probas_flat = test_probas_stacked.reshape(len(y_test), -1)  # (N_test, S * C)\n\n    # Custom predict_fn for SHAP that takes flat probas and runs Choquet Fusion\n    def ensemble_predict_fn_shap(x_flat_batch):\n        x_flat_batch = np.asarray(x_flat_batch, dtype=np.float64)\n        if x_flat_batch.ndim == 1:\n            x_flat_batch = x_flat_batch.reshape(1, -1)\n        N_batch = x_flat_batch.shape[0]\n        p3d = x_flat_batch.reshape(N_batch, ens.n, ens.n_classes)\n        return choquet_batch(p3d, ens.mu)\n\n    # Select background size for KernelExplainer\n    background_size = min(40, len(val_probas_flat))\n    background_data = val_probas_flat[:background_size]\n\n    print(\"Initializing SHAP KernelExplainer on ensemble model...\")\n    explainer = shap.KernelExplainer(ensemble_predict_fn_shap, background_data)\n\n    # Explain 10 random samples from the test set for local/global summary\n    rng = np.random.default_rng(SEED if 'SEED' in globals() else 42)\n    shap_indices = rng.choice(len(test_probas_flat), size=min(10, len(test_probas_flat)), replace=False)\n    \n    print(f\"SHAP explainer running on {len(shap_indices)} random test samples...\")\n    shap_values = explainer.shap_values(test_probas_flat[shap_indices])\n\n    print(\"SHAP explanation computed. Generating Summary Plot...\")\n    \n    plt.figure(figsize=(10, 8))\n    shap.summary_plot(\n        shap_values,\n        test_probas_flat[shap_indices],\n        feature_names=feature_names,\n        class_names=shap_class_names,\n        show=False\n    )\n    plt.title(f\"Ensemble SHAP Summary Plot\", fontweight='bold')\n    plt.tight_layout()\n    shap_plot_path = ARTIFACT_DIR / 'fi_ttx_shap_summary.png'\n    plt.savefig(shap_plot_path, dpi=300, bbox_inches='tight')\n    plt.show()\n    print('Saved SHAP summary plot to:', shap_plot_path)\n","metadata":{"execution":{"iopub.status.busy":"2026-05-21T05:32:46.461890Z","iopub.status.idle":"2026-05-21T05:32:46.462341Z","shell.execute_reply.started":"2026-05-21T05:32:46.462095Z","shell.execute_reply":"2026-05-21T05:32:46.462121Z"},"trusted":true},"outputs":[],"execution_count":null},{"id":"e026b9e0-3985-4388-9444-ad33d4b1815a","cell_type":"markdown","source":"## 8. Lưu Model & Benchmark","metadata":{}},{"id":"bdafe64e-26f9-495e-bc1c-0bc6c0d0552b","cell_type":"code","source":"import pickle\n\n# ── Lưu ensemble model ───────────────────────────────────────────────────────\n_state = {'model_names': ens.model_names, 'n_classes': ens.n_classes,\n           'mu_vec': ens.mu.to_vec().tolist(), 'shapley': ens.get_shapley()}\nwith open(ARTIFACT_DIR/'fi_ttx_ensemble.pkl','wb') as _f: pickle.dump(_state, _f)\nprint(\"Ensemble saved:\", ARTIFACT_DIR/'fi_ttx_ensemble.pkl')\n\n# ── Benchmark comparison ─────────────────────────────────────────────────────\n_src = [\n    ('FI_TTX', ARTIFACT_DIR/'fi_ttx_metrics.csv'),\n    ('transformer_bilstm', ARTIFACT_DIR/'transformer_bilstm_metrics.csv'),\n    ('tcn', ARTIFACT_DIR/'tcn_metrics.csv'),\n    ('xgboost', ARTIFACT_DIR/'xgboost_metrics.csv'),\n    ('lstm', ARTIFACT_DIR/'lstm_metrics.csv'),\n    ('patchtst', ARTIFACT_DIR/'patchtst_metrics.csv'),\n    ('lightgbm', ARTIFACT_DIR/'lightgbm_metrics.csv'),\n]\n_frames = []\nfor _nm, _p in _src:\n    if _p.exists():\n        _df = pd.read_csv(_p); _df['Model'] = _nm; _frames.append(_df)\n\nif _frames:\n    _cmp = pd.concat(_frames, ignore_index=True)\n    _cols = [c for c in ['Model','Split','Accuracy','Macro_F1','Weighted_F1','AUC','QWK'] if c in _cmp.columns]\n    _cmp = _cmp[_cols].sort_values(['Split','Macro_F1'],ascending=[True,False]).reset_index(drop=True)\n    try: from IPython.display import display; display(_cmp)\n    except: print(_cmp.to_string(index=False))\n    _cmp.to_csv(ARTIFACT_DIR/'fi_ttx_benchmark.csv', index=False)\n    print(\"Benchmark saved.\")\nelse:\n    print(\"[INFO] Chưa có file metric baseline để so sánh.\")\n\nprint(\"\\n\" + \"=\"*65)\nprint(\"HOÀN THÀNH: FI_TTX\")\nprint(\"=\"*65)\nmdf2 = pd.DataFrame([val_metrics, test_metrics])\nprint(mdf2.to_string(index=False))\n","metadata":{"execution":{"iopub.status.busy":"2026-05-21T05:32:46.463879Z","iopub.status.idle":"2026-05-21T05:32:46.464240Z","shell.execute_reply.started":"2026-05-21T05:32:46.464094Z","shell.execute_reply":"2026-05-21T05:32:46.464113Z"},"trusted":true},"outputs":[],"execution_count":null}]}